@startuml 06-saga-simple
title Saga SIMPLE de principio a fin: un único paso síncrono

box "Adaptadores de entrada" #EFF5FB
  participant "TrabajadorOrdenes\n+ ProcesadorOrdenSaga" as TRAB
end box
box "Aplicación" #F5FBEF
  participant "ManejadorTareasSaga" as MANEJ
  participant "ServicioSagasSucesoras" as SSUC
end box
box "Dominio" #FBF5EF
  participant "SagaSimple" as SAGA
end box
box "Adaptadores de salida" #F3EFFB
  participant "RepositorioSagasSucesoras\n(BBDD sagas)" as REPOS
  participant "PuertoSimple\n(REST al servicio externo)" as PSIM
  participant "Tabla ordenes" as ORD
  participant "PuertoEventos" as EVT
end box

== Arranque: el pool reclama la orden ARRANCAR_SAGA (creada en 03) ==
TRAB -> ORD ++ : reclamar orden PENDIENTE (lease)
return Orden (ARRANCAR_SAGA)
TRAB -> MANEJ ++ : procesar(TareaSaga.ArrancarSaga)
MANEJ -> SSUC ++ : continuar(sagaId)
group Transacción
  SSUC -> REPOS ++ : cargar(id)
  return SagaSimple INICIADA
  SSUC -> SAGA ++ : continuar() -> iniciar()
  SAGA -> SAGA : estado = EN_CURSO\nSIMPLE -> SOLICITADO
  return [Decision.Ejecutar(SIMPLE)]
  SSUC -> REPOS ++ : guardar(saga)
  return
end

== Paso SIMPLE y finalización ==
SSUC -> PSIM ++ : ejecutar(EjecutarSimple\n(datoNegocio1Id, refPaso7))
return RefSimple
SSUC -> SSUC : pasoCompletado(id, SIMPLE, resultado)
group Transacción
  SSUC -> REPOS ++ : cargar(id)
  return saga
  SSUC -> SAGA ++ : completar(SIMPLE, refSimple)
  SAGA -> SAGA : finalizar():\nestado = COMPLETADA
  return [PublicarEvento(SagaCompletada)]
  SSUC -> REPOS ++ : guardar(saga)
  return
end
SSUC -> EVT ++ : publicar(SagaCompletada)
return
return
return
TRAB -> ORD ++ : finalizar(orden, COMPLETADA)
return

note over SSUC, PSIM
  Ante ExcepcionServicioExterno: backoff exponencial y,
  si se agota, ticket a soporte — ver 07.
end note
@enduml
