@startuml 13-maquinas-de-estado
title Máquinas de estado de NEGOCIO (EstadoSaga* + ResultadoOrden) y el modelo OPERATIVO (atributos, no FSM)
' Sin Graphviz instalado: usar el motor de layout embebido
!pragma layout smetana

state "EstadoSagaPrincipal (SagaPrincipal)" as MPrincipal {
  state INICIAL
  state PASO1_HECHO
  state PASO2_HECHO
  state PASO3_HECHO
  state PASO4_HECHO
  state PASO5_HECHO
  state PASO6_HECHO
  state PASO7_HECHO
  state TERMINADA
  state COMPENSAR_PASO2
  state COMPENSAR_PASO1
  state CANCELADA

  [*] --> INICIAL : crear(id, externalId, datoNegocio3, datoNegocio2)
  INICIAL --> PASO1_HECHO : aplicarYAvanzar(ResultadoPaso1)
  PASO1_HECHO --> PASO2_HECHO : aplicarYAvanzar(ResultadoPaso2)
  PASO2_HECHO --> PASO3_HECHO : aplicarYAvanzar(ResultadoPaso3)
  PASO3_HECHO --> PASO4_HECHO : aplicarYAvanzar(ResultadoPaso4)
  PASO4_HECHO --> PASO5_HECHO : aplicarYAvanzar(ResultadoPaso5)
  PASO5_HECHO --> PASO6_HECHO : aplicarYAvanzar(ResultadoPaso6)
  PASO6_HECHO --> PASO7_HECHO : aplicarYAvanzar(ResultadoPaso7)
  PASO7_HECHO --> TERMINADA : aplicarYAvanzar(ResultadoPaso8)\n(punto de no retorno ya superado)
  TERMINADA --> [*] : resultadoFinal() = FINALIZADA_OK

  INICIAL --> CANCELADA : cancelar(quien, motivo)
  PASO1_HECHO --> COMPENSAR_PASO1 : cancelar(quien, motivo)
  PASO2_HECHO --> COMPENSAR_PASO2 : cancelar(quien, motivo)
  PASO3_HECHO --> COMPENSAR_PASO2 : cancelar(quien, motivo)
  PASO4_HECHO --> COMPENSAR_PASO2 : cancelar(quien, motivo)
  PASO5_HECHO --> COMPENSAR_PASO2 : cancelar(quien, motivo)
  PASO6_HECHO --> COMPENSAR_PASO2 : cancelar(quien, motivo)
  COMPENSAR_PASO2 --> COMPENSAR_PASO1 : compensacionCompletada()\n(el servicio de la saga ya ejecutó\npuertoPaso2.compensar)
  COMPENSAR_PASO1 --> CANCELADA : compensacionCompletada()\n(el servicio de la saga ya ejecutó\npuertoPaso1.compensar)
  CANCELADA --> [*] : resultadoFinal() = FINALIZADA_COMPENSADA
  PASO7_HECHO --> PASO7_HECHO : cancelar() lanza\nPuntoNoRetornoSuperadoException
  COMPENSAR_PASO2 --> COMPENSAR_PASO2 : cancelar() no-op idempotente
  COMPENSAR_PASO1 --> COMPENSAR_PASO1 : cancelar() no-op idempotente
  CANCELADA --> CANCELADA : cancelar() no-op idempotente
  TERMINADA --> TERMINADA : cancelar() lanza\nOrdenYaCompletadaException
}

state "EstadoSagaSecundaria1 (SagaSecundaria1)" as MSec1 {
  state INICIAL2 as "INICIAL"
  state INICIO_HECHO
  state TERMINADA2 as "TERMINADA"

  [*] --> INICIAL2 : crear(id, ArranqueSecundaria1)
  INICIAL2 --> INICIO_HECHO : aplicarYAvanzar(Iniciada(refInicio))
  INICIO_HECHO --> TERMINADA2 : aplicarYAvanzar(Confirmada(refConfirmacion))
  TERMINADA2 --> [*] : resultadoFinal() = FINALIZADA_OK
}

state "EstadoSagaSecundaria2 (SagaSecundaria2)" as MSec2 {
  state INICIAL3 as "INICIAL"
  state ESPERANDO_RESPUESTA
  state TERMINADA3 as "TERMINADA"

  [*] --> INICIAL3 : crear(id, ArranqueSecundaria2)
  INICIAL3 --> ESPERANDO_RESPUESTA : solicitudEnviada()\n(tras puerto.solicitar REST)
  ESPERANDO_RESPUESTA --> TERMINADA3 : respuestaRecibida(ref)\n(evento Kafka o conciliación\nDisponible(ref))
  ESPERANDO_RESPUESTA --> INICIAL3 : volverASolicitar()\n(evento Kafka de error o\nconciliación FalloRegistrado)
  TERMINADA3 --> [*] : resultadoFinal() = FINALIZADA_OK
}

state "EstadoSagaSecundaria3 (SagaSecundaria3)" as MSec3 {
  state INICIAL4 as "INICIAL"
  state TERMINADA4 as "TERMINADA"

  [*] --> INICIAL4 : crear(id, ArranqueSecundaria3)
  INICIAL4 --> TERMINADA4 : aplicarYAvanzar(Ejecutada(refEjecucion))
  TERMINADA4 --> [*] : resultadoFinal() = FINALIZADA_OK
}

state "ResultadoOrden (OrdenRoot.resultado) — estado OPERATIVO final, no de negocio" as MResultado {
  state VIVA as "null (viva)"
  state FINALIZADA_OK
  state FINALIZADA_COMPENSADA

  [*] --> VIVA : OrdenRoot.nueva(saga, ahora)
  VIVA --> FINALIZADA_OK : finalizar(saga.resultadoFinal())\n[saga.terminada() con FSM normal]
  VIVA --> FINALIZADA_COMPENSADA : finalizar(saga.resultadoFinal())\n[SagaPrincipal en CANCELADA]
  FINALIZADA_OK --> [*] : ServicioLimpiezaDatos.purgarAnterioresA(corte)
  FINALIZADA_COMPENSADA --> [*] : ServicioLimpiezaDatos.purgarAnterioresA(corte)
}

note bottom of MResultado
  intentos, proximoReintentoEn, tokenTrabajador/tokenExpiraEn (lease)
  y ticketAbiertoEn NO son una FSM: son atributos operativos de
  OrdenRoot que cambian con cada método (programarReintento(),
  resetearIntentos(), asignarToken()/renovarLease()/liberarToken(),
  marcarTicketAbierto()) independientemente del estado de negocio
  de la saga que contiene. Ya no existen EstadoTicket ni EstadoPaso:
  el ticket es ticketAbiertoEn (Instant o null) y el "paso pendiente"
  se deriva de (tipo, estado) sin un enum de paso propio.
end note

@enduml
