@startuml 15-clases-aplicacion
title Capa de aplicación (business.ordermanager.aplicacion): casos de uso, servicios y puertos
!pragma layout smetana
hide empty members
skinparam classAttributeIconSize 0

package "puerto.entrada (casos de uso)" {
  interface CasoUsoIniciarTramitacion {
    +iniciar(ComandoIniciarTramitacion) : SagaId
  }
  interface "CasoUsoProcesarResultadoPaso<P>" as CasoUsoProcesarResultadoPaso {
    +pasoCompletado(id, paso : P, resultado, msgId)
    +pasoFallido(id, paso : P, motivo, msgId)
  }
  interface CasoUsoIntervenirSaga {
    +cancelarPrincipal(id, quien, motivo)
    +reintentarPaso(tipo, id, nombrePaso, quien)
    +marcarPasoOk(tipo, id, nombrePaso, quien, ...)
  }
  interface CasoUsoConsultarSagasSoporte {
    +sagasBloqueadas() : List<SagaResumen>
    +sagasEnEjecucion() : List<SagaResumen>
    +buscar(FiltroSagas) : List<SagaResumen>
    +vistaTramitacion(externalId) : VistaTramitacion
    +detalle(tipo, id) : SagaDetalle
  }
  interface CasoUsoLimpiarDatosAntiguos {
    +purgarAnterioresA(corte) : ResultadoLimpieza
  }
}

package "servicio" {
  abstract class "ServicioSagaBase<P, S extends Saga<P>>" as Base <<@Service>> {
    #tx : UnidadDeTrabajo
    #dedup : PuertoMensajesProcesados
    #cola : PuertoColaTareas
    #tickets : PuertoTicketsSoporte
    +continuar(id)
    +pasoCompletado / pasoFallido / reintentar
    +reanudarPaso / marcarPasoOk
    #procesar(msgId, id, accion)  «tx + dedup + reintento optimista»
    #despachar(id, decisiones)  «I/O fuera de la tx»
    {abstract} #cargar(id) : S
    {abstract} #guardar(S)
    {abstract} #ejecutar(id, paso, cmd)
    #alSolicitarEjecucion(saga, d)  «hook tx»
    #arrancarSaga(saga, d)  «hook tx»
    #compensar(id, paso, cmd)
  }

  class ServicioEncolarTramitacion <<@Service>> {
    +iniciar(cmd) : SagaId
  }
  note bottom of ServicioEncolarTramitacion
    Intake durable: genera SagaId,
    encola TareaSaga.IniciarTramitacion
    y responde 202 al instante.
  end note

  class ManejadorTareasSaga <<@Service>> {
    +procesar(TareaSaga)
  }
  note bottom of ManejadorTareasSaga
    Router: switch por tipo de tarea y TipoSaga.
    Única frontera donde PasoSaga se baja
    al enum concreto de cada saga.
  end note

  class ServicioSagaPrincipal <<@Service>> {
    -repo + 3 repos secundarios
    -puertoPaso1..puertoPaso8
    +iniciarOContinuar(id, externalId, ...)
    +cancelar(id, quien, motivo)
    #arrancarSaga: crea la secundaria +\nencola ArrancarSaga(id, tipo) en la tx
  }
  class ServicioSagaSecundaria1 <<@Service>> {
    -repo : RepositorioSagaSecundaria1
    -puerto : PuertoSagaSecundaria1
    #ejecutar: INICIO y CONFIRMACION\nsíncronos, reentran con el resultado
  }
  class ServicioSagaSecundaria2 <<@Service>> {
    -repo : RepositorioSagaSecundaria2
    -puerto : PuertoSagaSecundaria2
    TIMEOUT_RESPUESTA = 24 h
    +timeoutVencido(id)
    #alSolicitarEjecucion: encola el timeout en la tx
    #ejecutar: REST de solicitud; NO reentra\n(la respuesta llega por Kafka)
  }
  class ServicioSagaSecundaria3 <<@Service>> {
    -repo : RepositorioSagaSecundaria3
    -puerto : PuertoSagaSecundaria3
    #ejecutar: un paso síncrono
  }

  class ServicioSoporteSagas <<@Service>> {
    -principal + 3 secundarias
    -consultas : PuertoConsultaSagasSoporte
    resuelve nombrePaso -> enum por TipoSaga
  }

  class ServicioLimpiezaDatos <<@Service>> {
    -repoPrincipal + 3 repos secundarios
    -dedup / cola / tx
    +purgarAnterioresA(corte) : ResultadoLimpieza
  }

  class ReintentoOptimista <<package-private>> {
    {static} ejecutar(Supplier<T>) : T
    MAX_REINTENTOS = 5
  }
  class FabricaResultadoManual <<@Factory, package-private>> {
    {static} paraPaso(PasoSaga, Map datos) : ResultadoPaso
  }
}

package "tarea" {
  interface TareaSaga <<sealed>> {
    +sagaId() : SagaId
    IniciarTramitacion(sagaId, externalId, datos, datoNegocio2)
    ArrancarSaga(sagaId, tipo)
    Reintentar(tipo, sagaId, paso, intentoNum)
    TimeoutSagaSecundaria2(sagaId)
    ResultadoSagaSecundaria2Ok(sagaId, ref, mensajeId)
    ResultadoSagaSecundaria2Error(sagaId, ..., reintentable, mensajeId)
  }
}

package "puerto.salida" {
  interface RepositorioSagaPrincipal <<@Repository>> {
    +crear / existe / cargar / guardar
    +purgarFinalizadasAntesDe(corte)
  }
  interface "RepositorioSagaSecundaria1/2/3" as ReposSecundarias <<@Repository>> {
    +crear / cargar / guardar
    +purgarFinalizadasAntesDe(corte)
  }
  interface UnidadDeTrabajo {
    +enTransaccion(Supplier<T>) : T
  }
  interface PuertoColaTareas {
    +encolar(tarea)
    +encolar(tarea, noAntesDe)
    +purgarTerminadasAntesDe(corte)
  }
  interface PuertoMensajesProcesados {
    +yaProcesado(msgId) : boolean
    +registrar(msgId)
    +purgarAnterioresA(corte)
  }
  interface PuertoTicketsSoporte {
    +abrir(sagaId, tipo, paso, motivo, ...) : TicketId
  }
  interface PuertoConsultaSagasSoporte {
    +sagasBloqueadas() / sagasEnEjecucion()
    +buscar(filtro) / vistaTramitacion(externalId)
    +detalle(tipo, id)
  }
  interface "PuertoPaso1 .. PuertoPaso8" as PuertosPaso {
    +ejecutar(cmd)
    +compensar(cmd)  «solo 1 y 2»
  }
  interface PuertoSagaSecundaria1 {
    +iniciar(cmd) / confirmar(cmd)  «REST síncrono»
  }
  interface PuertoSagaSecundaria2 {
    +solicitar(sagaId, cmd)  «REST; respuesta\ndiferida por evento Kafka»
  }
  interface PuertoSagaSecundaria3 {
    +ejecutar(cmd)  «REST síncrono»
  }
}

' Layout: apilar los puertos en columnas (smetana los pone en fila)
RepositorioSagaPrincipal -[hidden]down- ReposSecundarias
ReposSecundarias -[hidden]down- UnidadDeTrabajo
PuertoColaTareas -[hidden]down- PuertoMensajesProcesados
PuertoMensajesProcesados -[hidden]down- PuertoTicketsSoporte
PuertosPaso -[hidden]down- PuertoSagaSecundaria1
PuertoSagaSecundaria1 -[hidden]down- PuertoSagaSecundaria2
PuertoSagaSecundaria2 -[hidden]down- PuertoSagaSecundaria3
CasoUsoIniciarTramitacion -[hidden]down- CasoUsoProcesarResultadoPaso
CasoUsoIntervenirSaga -[hidden]down- CasoUsoConsultarSagasSoporte
CasoUsoConsultarSagasSoporte -[hidden]down- CasoUsoLimpiarDatosAntiguos

' Realizaciones
CasoUsoIniciarTramitacion <|.. ServicioEncolarTramitacion
CasoUsoProcesarResultadoPaso <|.. Base
CasoUsoIntervenirSaga <|.. ServicioSoporteSagas
CasoUsoConsultarSagasSoporte <|.. ServicioSoporteSagas
CasoUsoLimpiarDatosAntiguos <|.. ServicioLimpiezaDatos

' Herencia de la base
Base <|-- ServicioSagaPrincipal
Base <|-- ServicioSagaSecundaria1
Base <|-- ServicioSagaSecundaria2
Base <|-- ServicioSagaSecundaria3

' Dependencias
ServicioEncolarTramitacion --> PuertoColaTareas
ManejadorTareasSaga --> ServicioSagaPrincipal
ManejadorTareasSaga --> ServicioSagaSecundaria1
ManejadorTareasSaga --> ServicioSagaSecundaria2
ManejadorTareasSaga --> ServicioSagaSecundaria3
ManejadorTareasSaga ..> TareaSaga : despacha por tipo
ServicioSoporteSagas --> ServicioSagaPrincipal
ServicioSoporteSagas --> ServicioSagaSecundaria1
ServicioSoporteSagas --> ServicioSagaSecundaria2
ServicioSoporteSagas --> ServicioSagaSecundaria3
ServicioSoporteSagas --> PuertoConsultaSagasSoporte
ServicioSoporteSagas ..> FabricaResultadoManual
Base --> UnidadDeTrabajo
Base --> PuertoMensajesProcesados
Base --> PuertoColaTareas
Base --> PuertoTicketsSoporte
Base ..> ReintentoOptimista
ServicioSagaPrincipal --> RepositorioSagaPrincipal
ServicioSagaPrincipal --> ReposSecundarias : crea secundarias\nen la misma tx
ServicioSagaPrincipal --> PuertosPaso
ServicioSagaSecundaria1 --> ReposSecundarias
ServicioSagaSecundaria1 --> PuertoSagaSecundaria1
ServicioSagaSecundaria2 --> ReposSecundarias
ServicioSagaSecundaria2 --> PuertoSagaSecundaria2
ServicioSagaSecundaria3 --> ReposSecundarias
ServicioSagaSecundaria3 --> PuertoSagaSecundaria3
ServicioLimpiezaDatos --> RepositorioSagaPrincipal
ServicioLimpiezaDatos --> ReposSecundarias
ServicioLimpiezaDatos --> PuertoMensajesProcesados
ServicioLimpiezaDatos --> PuertoColaTareas
ServicioLimpiezaDatos --> UnidadDeTrabajo

@enduml
