@startuml 09-limpieza-datos
title Limpieza periódica: purgar órdenes finalizadas y antiguas

box "Adaptadores de entrada" #EFF5FB
  participant "PlanificadorLimpieza\n(@Scheduled cron 0 0 3 * * *)" as PLAN
end box
box "Aplicación" #F5FBEF
  participant "ServicioLimpiezaDatos" as LIMP
end box
box "Adaptadores de salida" #F3EFFB
  participant "AdaptadorRepositorioOrden" as REPO
end box

note over PLAN, LIMP
  Solo borra órdenes finalizadas (completadaEn no nula) y ya viejas:
  cualquier orden viva (completadaEn == null), sea cual sea su
  estado o sus intentos, sobrevive siempre a la limpieza.
end note

[o-> PLAN : dispara el cron (cada noche a las 03:00)
activate PLAN
PLAN -> PLAN : corte = Instant.now().minus(retencion)\n(ordermanager.limpieza.retencion-dias, por defecto 30)
PLAN -> LIMP ++ : purgarAnterioresA(corte)

group Transacción única (@Transactional)
  LIMP -> REPO ++ : purgarFinalizadasAntesDe(corte)
  REPO -> REPO : ids = ordenes.idsFinalizadasAntesDe(corte)\n(SELECT orden_id FROM orden WHERE completada_en\nIS NOT NULL AND actualizada_en < :corte)
  alt ids.isEmpty()
    REPO -> REPO : return 0
  else hay ids
    REPO -> REPO : ordenes.borrarAuditoriaPorIds(ids)\n(DELETE FROM proceso_auditoria WHERE orden_id IN ids)
    loop por cada MapeadorProceso registrado (uno por tipo)
      REPO -> REPO : mapeador.borrarContexto(ids)\n-- borra SOLO su propia satélite (proceso_saga_principal\n/ _secundaria1 / _secundaria2 / _secundaria3, ver 23);\nlas filas de otros tipos no matchean
    end
    REPO -> REPO : ordenes.borrarPorIds(ids)\n(DELETE FROM orden WHERE orden_id IN ids)
    REPO -> REPO : return ids.size()
  end
  return nº órdenes borradas
end
return ResultadoLimpieza(ordenes)
PLAN -> PLAN : log.info("Limpieza de datos (corte {}): {} órdenes borradas", ...)
deactivate PLAN

note over REPO
  Sin ON DELETE CASCADE en NINGUNA tabla (prohibido, ver CLAUDE.md):
  cada borrado es explícito, en la misma transacción y en orden
  hijas -> padre. Desde la fusión de la fase 2, orden es el padre
  (antes lo era proceso): proceso_auditoria y cada satélite de
  MapeadorProceso son hijas de orden por FK (una tabla por tipo de
  orden) y se borran antes; orden se borra el último, ya libre de FKs
  de sus hijas. Todo o nada: un solo commit para órdenes + satélites.
end note
@enduml
