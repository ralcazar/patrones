@startuml 05-saga-secuencial
title Saga SECUENCIAL de principio a fin: SECUENCIAL1 -> SECUENCIAL2, síncronos con checkpoint

box "Adaptadores de entrada" #EFF5FB
  participant "TrabajadorOrdenes\n+ ProcesadorOrdenSaga" as TRAB
end box
box "Aplicación" #F5FBEF
  participant "ManejadorTareasSaga" as MANEJ
  participant "ServicioSagasSucesoras" as SSUC
end box
box "Dominio" #FBF5EF
  participant "SagaSecuencial" as SAGA
end box
box "Adaptadores de salida" #F3EFFB
  participant "RepositorioSagasSucesoras\n(BBDD sagas)" as REPOS
  participant "PuertoSecuencial\n(REST al servicio externo)" as PSEC
  participant "Tabla ordenes" as ORD
  participant "PuertoEventos" as EVT
end box

== Arranque: el pool reclama la orden ARRANCAR_SAGA (creada en 03) ==
TRAB -> ORD ++ : reclamar orden PENDIENTE (lease)
return Orden (ARRANCAR_SAGA)
TRAB -> MANEJ ++ : procesar(TareaSaga.ArrancarSaga)
MANEJ -> SSUC ++ : continuar(sagaId)
group Transacción
  SSUC -> REPOS ++ : cargar(id)
  return SagaSecuencial INICIADA
  SSUC -> SAGA ++ : continuar() -> iniciar()
  SAGA -> SAGA : estado = EN_CURSO\nSECUENCIAL1 -> SOLICITADO
  return [Decision.Ejecutar(SECUENCIAL1)]
  SSUC -> REPOS ++ : guardar(saga)
  return
end

== Paso SECUENCIAL1 ==
SSUC -> PSEC ++ : iniciar(EjecutarSecuencial1\n(datoNegocio1Id, refPaso1))
return RefSecuencial1
SSUC -> SSUC : pasoCompletado(id, SECUENCIAL1, resultado)
group Transacción (checkpoint)
  SSUC -> REPOS ++ : cargar(id)
  return saga
  SSUC -> SAGA ++ : completar(SECUENCIAL1, refSecuencial1)
  SAGA -> SAGA : guarda refSecuencial1 (la consume SECUENCIAL2)\nSECUENCIAL2 -> SOLICITADO
  return [Decision.Ejecutar(SECUENCIAL2)]
  SSUC -> REPOS ++ : guardar(saga)
  return
end

== Paso SECUENCIAL2 y finalización ==
SSUC -> PSEC ++ : confirmar(EjecutarSecuencial2\n(refSecuencial1))
return RefSecuencial2
SSUC -> SSUC : pasoCompletado(id, SECUENCIAL2, resultado)
group Transacción
  SSUC -> REPOS ++ : cargar(id)
  return saga
  SSUC -> SAGA ++ : completar(SECUENCIAL2, refSecuencial2)
  SAGA -> SAGA : finalizar():\nestado = COMPLETADA
  return [PublicarEvento(SagaCompletada)]
  SSUC -> REPOS ++ : guardar(saga)
  return
end
SSUC -> EVT ++ : publicar(SagaCompletada)
return
return
return
TRAB -> ORD ++ : finalizar(orden, COMPLETADA)
return

note over SSUC, PSEC
  Ante ExcepcionServicioExterno en cualquiera de los dos pasos:
  backoff exponencial y, si se agota, ticket a soporte — ver 07.
end note
@enduml
