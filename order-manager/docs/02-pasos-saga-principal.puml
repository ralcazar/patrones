@startuml 02-pasos-saga-principal
title Saga principal: reclamo de token + bucle PASO1..PASO8, REST fuera de tx, checkpoint transaccional por paso

box "Adaptadores de entrada" #EFF5FB
  participant "TrabajadorContinuacion\n(worker pull @Async)" as TRAB
end box
box "Aplicación" #F5FBEF
  participant "ServicioContinuarOrden" as CONT
  participant "ServicioSagaPrincipal\n(ProcesadorOrden)" as ORQ
end box
box "Dominio" #FBF5EF
  participant "OrdenRoot" as ORDEN
  participant "SagaPrincipal" as SAGA
end box
box "Adaptadores de salida" #F3EFFB
  participant "AdaptadorRepositorioOrden" as REPO
  participant "PuertoPaso1 .. PuertoPaso8\n(según el paso actual)" as PASOS
end box

note over TRAB, CONT
  Continuación de 01: PlanificadorContinuacion vio trabajo pendiente
  (hayTrabajoPendiente()) y despertó hasta N workers @Async. Cada
  TrabajadorContinuacion hace pull con continuarSiguiente(), que
  relee candidatas frescas y reclama la primera que gane.
end note

TRAB -> CONT ++ : continuarSiguiente()
CONT -> REPO ++ : buscarEjecutables(Instant.now(), lote)
return [CandidataOrden(ordenId, TipoOrden("PRINCIPAL")), ...]
CONT -> CONT : reclamarYEjecutar(ordenId, tipo)

CONT -> CONT ++ : self.reclamarToken(ordenId)  -- vía proxy (@Transactional; auto-invocación\nsaltaría el proxy, ver ConfiguracionOrderManager)
group Transacción (ConcurrenciaOptimistaException -> false, otro pod la tiene)
  CONT -> REPO ++ : cargar(ordenId)
  return orden
  CONT -> ORDEN ++ : estaViva()
  return true
  CONT -> ORDEN ++ : tieneTokenVigente(ahora)
  return false
  CONT -> ORDEN ++ : asignarToken(UUID.randomUUID(), lease, ahora)
  return tokenExpiraEn = ahora + lease
  CONT -> REPO ++ : guardar(orden)
  return
end
return true

CONT -> CONT : procesador = procesadores.get(tipo)  -- Map<TipoOrden, ProcesadorOrden>\n(ServicioSagaPrincipal registrado bajo SagaPrincipal.TIPO)

loop while (true) hasta Aparcar / Finalizada / excepción
  CONT -> REPO ++ : cargar(ordenId)  [ÚNICA carga del paso, antes del REST:\nesta MISMA instancia (con su version) es la que\nse guarda al terminar el paso o al reintentar]
  return orden

  CONT -> ORQ ++ : ejecutarPaso(orden)
  ORQ -> ORDEN ++ : orden.proceso()
  return saga (SagaPrincipal)
  ORQ -> SAGA ++ : saga.estado()
  return PASOn_HECHO (no está en COMPENSAR_*/CANCELADA)
  ORQ -> ORQ : ejecutarPasoNormal(orden, saga)
  ORQ -> SAGA ++ : saga.comandoActual()
  return ComandoPasoPrincipal.EjecutarPasoN(...)

  == REST fuera de tx ==
  ORQ -> PASOS ++ : puertoPasoN.ejecutar(EjecutarPasoN(...))
  alt éxito
    return ResultadoPasoN(ref)
    ORQ -> ORQ ++ : self.aplicarPasoNormal(orden, saga, resultado)  -- vía proxy (@Transactional;\nauto-invocación saltaría el proxy, ver ConfiguracionSagas)
    group Transacción: checkpoint del paso (negocio + ejecución, un solo guardar)
      ORQ -> SAGA ++ : saga.aplicarYAvanzar(resultado)
      SAGA -> SAGA : ctx = ctx.aplicar(r); avanzar()
      return
      ORQ -> SAGA ++ : saga.terminada()
      return false (PASO1_HECHO .. PASO7_HECHO)
      ORQ -> ORDEN ++ : resetearIntentos()
      return intentos=0, ticketAbiertoEn=null
      ORQ -> ORDEN ++ : renovarLease(lease, Instant.now())
      return tokenExpiraEn = ahora + lease
      ORQ -> REPO ++ : guardar(orden)
      return
      note right of REPO
        Guardar lleva la version de la carga hecha por CONT antes
        del REST. Si otro actor escribió mientras el REST estaba en
        vuelo (takeover de un pod zombi, soporte), falla con
        ConcurrenciaOptimistaException y el pod se retira.
      end note
    end
    return HayMasTrabajo()
    return HayMasTrabajo()
    CONT -> CONT : switch(señal): HayMasTrabajo -> continue el bucle
  else falla
    PASOS --> ORQ : lanza ExcepcionServicioExterno(motivo)
    deactivate PASOS
    ORQ --> CONT : se propaga sin capturar (RuntimeException)
    deactivate ORQ
    note right of CONT
      reclamarYEjecutar() la atrapa como RuntimeException y programa
      el reintento sobre la MISMA orden cargada arriba (fix del
      takeover seguro) — ver 07-error-ticket-soporte.
    end note
    CONT -> CONT ++ : self.programarReintento(orden)  -- vía proxy (@Transactional)
    group Transacción: reintento sobre la orden ya cargada (no se recarga)
      CONT -> ORDEN ++ : programarReintento(politica, Instant.now())
      return intentos++, proximoReintentoEn = ahora + esperaTras(intentos), token liberado
      CONT -> REPO ++ : guardar(orden)
      return
    end
    return
  end
end

note over SAGA
  Al completar PASO7, terminada() sigue en false pero la saga ya
  superó el punto de no retorno: deja de ser cancelable (ver 08).
  Al completar PASO8, terminada() pasa a true: la rama Finalizada()
  la cubre 03-finalizacion-saga-principal (misma tx de checkpoint).
end note
@enduml
