!pragma layout smetana
hide empty members
skinparam classAttributeIconSize 0

abstract class "ServicioSagaBase<PasoSagaSecundaria1,\nSagaSecundaria1Root> (ver 17)" as Base <<@Service>>

class ServicioSagaSecundaria1 <<@Service>> {
  #ejecutar: INICIO y CONFIRMACION síncronos,\nreentran con el resultado (checkpoint por paso)
}

package "puerto.salida" {
  interface RepositorioSagaSecundaria1 <<@Repository>> {
    +crear / cargar / guardar
