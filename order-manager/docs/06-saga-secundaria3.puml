@startuml 06-saga-secundaria3
title Saga SECUNDARIA3 de principio a fin: una única llamada REST y FINALIZADA_OK

box "Adaptadores de entrada" #EFF5FB
  participant "PlanificadorContinuacion\n(@Scheduled)" as PLAN
end box
box "Aplicación" #F5FBEF
  participant "ServicioContinuarSaga" as CONT
  participant "ServicioSagaSecundaria3\n(OrquestadorSaga)" as ORQ
end box
box "Dominio" #FBF5EF
  participant "OrdenRoot" as ORDEN
  participant "SagaSecundaria3Root" as SAGA
end box
box "Adaptadores de salida" #F3EFFB
  participant "AdaptadorRepositorioOrden" as REPO
  participant "PuertoSagaSecundaria3\n(REST al servicio externo)" as PSIM
end box

note over PLAN, CONT
  La hija SECUNDARIA3 nació en 03 con proximoReintentoEn = ahora:
  el planificador la recoge (reclamo de token omitido aquí,
  igual que en 02/04).
end note

PLAN -> CONT ++ : continuarCandidatas(limite)
CONT -> CONT : continuar(sagaId, SECUNDARIA3)
CONT -> ORQ ++ : ejecutarPaso(sagaId)
ORQ -> REPO ++ : cargar(sagaId)
return orden
ORQ -> SAGA ++ : (orden.saga()).comandoActual()
return ComandoPasoSecundaria3.Ejecutar(externalId, refPaso7)
ORQ -> PSIM ++ : ejecutar(cmd) -- REST fuera de tx
return ResultadoPasoSecundaria3.Ejecutada(refEjecucion)
group Transacción única: checkpoint del paso
  ORQ -> REPO ++ : cargar(sagaId)
  return orden
  ORQ -> SAGA ++ : (orden.saga()).aplicarYAvanzar(Ejecutada(ref))
  SAGA -> SAGA : refEjecucion = ref; estado = TERMINADA
  return
  ORQ -> SAGA ++ : (orden.saga()).resultadoFinal()
  return FINALIZADA_OK
  ORQ -> ORDEN ++ : finalizar(FINALIZADA_OK)
  return
  ORQ -> REPO ++ : guardar(orden)
  return
end
return Finalizada(FINALIZADA_OK)
CONT -> CONT : switch(señal): Finalizada -> return (fin del bucle)

note over ORQ, PSIM
  A diferencia de la principal y de secundaria1, este orquestador
  no comprueba terminada() antes de finalizar: el único paso
  EJECUCION siempre deja la saga en TERMINADA, así que
  ejecutarPaso() va derecho a finalizar(). Ante
  ExcepcionServicioExterno: propaga fuera de tx y
  ServicioContinuarSaga.continuar() programa reintento (backoff
  1..180 min) — ver 07. Nunca se cancela ni compensa.
end note
@enduml
