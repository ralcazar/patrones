@startuml 22-clases-aplicacion-soporte
title Aplicación — soporte, tickets y limpieza
!pragma layout smetana
hide empty members
skinparam classAttributeIconSize 0

package "puerto.entrada" {
  interface CasoUsoIntervenirSaga {
    +cancelarPrincipal(id, quien, motivo)
    +reintentarPaso(tipo, id, nombrePaso, quien)
    +marcarPasoOk(tipo, id, nombrePaso, quien,\njustificacion, datosManuales)
  }
  note bottom of CasoUsoIntervenirSaga
    nombrePaso se conserva por compatibilidad de firma y como
    dato informativo de auditoría, pero es opcional: cada saga
    tiene como mucho UN paso pendiente (el que marca su FSM), ya
    no hace falta identificarlo por su enum.
  end note
  interface CasoUsoConsultarSagasSoporte {
    +sagasBloqueadas() : List<SagaResumen>  «intentos >= 8»
    +sagasEnEjecucion() : List<SagaResumen>  «token vigente»
    +sagasConTicketPendiente() : List<SagaResumen>
    +buscar(FiltroSagas) : List<SagaResumen>
    +vistaTramitacion(externalId) : VistaTramitacion
    +detalle(tipo, id) : SagaDetalle
    record SagaResumen(id, tipo, externalId, estado : String,\nintentos, ticketAbiertoEn, proximoReintentoEn,\niniciadaEn, actualizadaEn)
    record FiltroSagas(estado : String, iniciadaDesde/Hasta,\nactualizadaDesde/Hasta)
    record PasoDetalle(nombrePaso, datosManualesObligatorios)
    record SagaDetalle(resumen, cancelable, pasos, auditoria)
    record VistaTramitacion(externalId, principal, secundarias)
  }
  note bottom of CasoUsoConsultarSagasSoporte
    Modelo de lectura CQRS puro: el adaptador resuelve con SQL
    sobre orden/saga sin cargar agregados; por eso "estado" viaja
    como String (el nombre del enum), no como EstadoSaga*.
  end note
  interface CasoUsoAbrirTicketsPendientes {
    +abrirTicketsPendientes() : int
  }
  interface CasoUsoLimpiarDatosAntiguos {
    +purgarAnterioresA(corte) : ResultadoLimpieza
    record ResultadoLimpieza(ordenes, mensajesDedup) { +total() }
  }
}

package "servicio" {
  class ServicioSoporteSagas <<@Service>> {
    -repo : RepositorioOrden
    -consultas : PuertoConsultaSagasSoporte
    +cancelarPrincipal(id, quien, motivo)  «@Transactional: saga.cancelar()+orden.despertar()»
    +reintentarPaso(tipo, id, nombrePaso, quien)  «@Transactional: orden.resetearIntentos()+despertar()»
    +marcarPasoOk(tipo, id, nombrePaso, quien, ...)  «@Transactional: saga.marcarPasoActualOkManual()+orden.despertar()»
    +sagasBloqueadas/EnEjecucion/ConTicketPendiente/buscar/\nvistaTramitacion/detalle  «delegan tal cual en consultas»
  }
  note bottom of ServicioSoporteSagas
    Cada intervención actúa DIRECTAMENTE sobre el agregado vía
    RepositorioOrden (un único agregado, un único guardar): no pasa
    por los servicios de saga de ejecución. despertar() la deja
    candidata inmediata para que el planificador la recoja (ver 08).
    @Transactional directamente en cada método público: se invocan
    cross-bean desde el adaptador de entrada, sin necesidad de self.
  end note

  class ServicioTicketsSoporte <<@Service>> {
    -pendientes : PuertoSagasTicketPendiente
    -tickets : PuertoTicketsSoporte
    -repo : RepositorioOrden
    -self : ServicioTicketsSoporte  «proxy auto-inyectado, @Lazy\n(ver ConfiguracionAplicacion); establecerSelf(self)»
    +abrirTicketsPendientes() : int
    -marcarAbierto(sagaId, apertura)  «ReintentoOptimista.ejecutar(\nself.aplicarMarcarAbierto(sagaId, apertura))»
    +aplicarMarcarAbierto(sagaId, apertura)  «@Transactional»
  }
  note bottom of ServicioTicketsSoporte
    1. pendientes.buscar(); 2. si no vacío, tickets.abrir(sagas) — UN
    ticket para todas, fuera de tx; 3. marcarAbierto por cada una
    llama a self.aplicarMarcarAbierto(...) -- vía proxy, para que
    @Transactional no se ignore por auto-invocación -- (at-least-once:
    si el proceso muere entre 2 y 3, el siguiente barrido repite el
    aviso).
  end note

  class ServicioLimpiezaDatos <<@Service>> {
    -repo : RepositorioOrden
    -dedup : PuertoMensajesProcesados
    +purgarAnterioresA(corte) : ResultadoLimpieza  «@Transactional»
  }
  note bottom of ServicioLimpiezaDatos
    @Transactional directo en el método (cross-bean, sin self):
    repo.purgarFinalizadasAntesDe(corte) +
    dedup.purgarAnterioresA(corte). Solo borra resultado != null y
    antiguo; cualquier orden viva sobrevive.
  }

  class "ReintentoOptimista" as Reintento <<package-private>> {
    {static} ejecutar(Supplier<T>) : T
    MAX_REINTENTOS = 5
  }
  note bottom of Reintento
    Reintenta ante ConcurrenciaOptimistaException: recarga y
    reaplica. Lo usa ServicioTicketsSoporte.marcarAbierto (poco
    probable pero posible: la orden estaba bloqueada, sin token).
  end note
}

package "puerto.salida" {
  interface PuertoConsultaSagasSoporte {
    +sagasBloqueadas() / sagasEnEjecucion()
    +sagasConTicketPendiente() / buscar(filtro)
    +vistaTramitacion(externalId) / detalle(tipo, id)
  }
  interface PuertoSagasTicketPendiente {
    +buscar() : List<SagaTicketPendiente>
    record SagaTicketPendiente(tipo, sagaId, externalId, intentos)
    «intentos >= 8 AND ticket_abierto_en IS NULL AND resultado IS NULL»
  }
  interface PuertoTicketsSoporte {
    +abrir(List<SagaTicketPendiente>)
    «UN ticket para todas: texto en el log, sin id»
  }
  interface "RepositorioOrden,\nPuertoMensajesProcesados (ver 17)" as PuertosNucleo
}

CasoUsoIntervenirSaga <|.. ServicioSoporteSagas
CasoUsoConsultarSagasSoporte <|.. ServicioSoporteSagas
CasoUsoAbrirTicketsPendientes <|.. ServicioTicketsSoporte
CasoUsoLimpiarDatosAntiguos <|.. ServicioLimpiezaDatos

ServicioSoporteSagas --> PuertoConsultaSagasSoporte
ServicioSoporteSagas --> PuertosNucleo
ServicioTicketsSoporte --> PuertoSagasTicketPendiente
ServicioTicketsSoporte --> PuertoTicketsSoporte
ServicioTicketsSoporte --> PuertosNucleo
ServicioTicketsSoporte ..> Reintento
ServicioLimpiezaDatos --> PuertosNucleo

note as NRuteo
  A diferencia del diseño anterior, ServicioSoporteSagas y
  ServicioTicketsSoporte ya NO delegan en los servicios de saga
  (ServicioSagaPrincipal/Secundaria1/2/3 — ver 18-21): mutan
  OrdenRoot/Saga directamente vía RepositorioOrden. La
  ejecución real de la compensación tras cancelarPrincipal() la
  recoge, asíncrona, el propio bucle de ServicioContinuarSaga
  (ver 08 y 17).
end note
@enduml
