@startuml 01-arranque-saga-nueva
title Arranque de una nueva saga: ServicioIniciarTramitacion crea el agregado; primer picking del planificador

box "Adaptadores de entrada" #EFF5FB
  participant "Adaptador de entrada\n(REST u otro, aún no\nimplementado en este esqueleto)" as ENTRADA
  participant "PlanificadorContinuacion\n(@Scheduled fixedDelay)" as PLAN
end box
box "Aplicación" #F5FBEF
  participant "ServicioIniciarTramitacion" as INICIAR
  participant "ServicioContinuarSaga" as CONT
end box
box "Dominio" #FBF5EF
  participant "SagaPrincipalRoot" as SAGA
  participant "OrdenRoot" as ORDEN
end box
box "Adaptadores de salida" #F3EFFB
  participant "AdaptadorRepositorioOrden" as REPO
end box

== Iniciar tramitación: crea el agregado completo (orden + saga) en una tx ==
[-> ENTRADA : inicia tramitación
activate ENTRADA
ENTRADA -> INICIAR ++ : iniciar(ComandoIniciarTramitacion(\nexternalId, datoNegocio3, datoNegocio2))
INICIAR -> INICIAR : sagaId = SagaId.nuevo()

group Transacción (UnidadDeTrabajo.enTransaccion)
  INICIAR -> SAGA ++ : SagaPrincipalRoot.crear(sagaId,\nexternalId, datoNegocio3, datoNegocio2)
  return saga (estado = INICIAL)
  INICIAR -> ORDEN ++ : OrdenRoot.nueva(saga, Instant.now())
  return orden (intentos=0, proximoReintentoEn=ahora,\ntoken=null, resultado=null, version=0)
  INICIAR -> REPO ++ : crear(orden)
  REPO -> REPO : sagas.save(entidadSagaDe(saga))
  REPO -> REPO : ordenes.save(entidadOrdenDe(orden))
  return
end
return sagaId
[<-- ENTRADA
deactivate ENTRADA

note right of INICIAR
  Al nacer con proximoReintentoEn = ahora, la orden queda
  candidata inmediata: no hace falta ningún evento ni cola;
  el siguiente picking del planificador la recoge sola.
end note

== Primer picking: el planificador la descubre como candidata ==
loop cada orden.planificador.intervalo-ms (por defecto 500 ms)
  PLAN -> CONT ++ : continuarCandidatas(limite)
  CONT -> REPO ++ : buscarEjecutables(Instant.now(), limite)
  REPO -> REPO : SELECT ... WHERE proximo_reintento_en <= :ahora\nAND resultado IS NULL AND (token_trabajador IS NULL\nOR token_expira_en <= :ahora)\nFETCH FIRST :limite ROWS ONLY
  return [CandidataOrden(sagaId, PRINCIPAL), ...]
  loop por cada candidata devuelta
    CONT -> CONT : continuar(candidata.sagaId(), candidata.tipo())
  end
  return
end

note over CONT
  continuar(sagaId, PRINCIPAL) reclama el token bajo optimistic
  lock y entra en el bucle de ejecutarPaso(): el reclamo del
  token y la cadena PASO1..PASO8 se detallan en
  02-pasos-saga-principal.
end note
@enduml
